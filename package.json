{
  "name": "clanki",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:worker": "wrangler dev",
    "dev:frontend": "vite",
    "dev": "bun run dev:worker & bun run dev:frontend",
    "build:worker": "tsc --noEmit -p tsconfig.worker.json",
    "build:frontend": "vite build && tsc --noEmit -p tsconfig.frontend.json",
    "build": "bun run build:worker && bun run build:frontend",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "DATABASE_URL=\"${DATABASE_URL:-$(grep '^DATABASE_URL=' .env | cut -d= -f2-)}\" sh -c '[ -n \"$DATABASE_URL\" ] || { echo \"Missing DATABASE_URL\"; exit 1; }; drizzle-kit migrate --config drizzle.config.ts'",
    "db:push": "DATABASE_URL=\"${DATABASE_URL:-$(grep '^DATABASE_URL=' .env | cut -d= -f2-)}\" sh -c '[ -n \"$DATABASE_URL\" ] || { echo \"Missing DATABASE_URL\"; exit 1; }; drizzle-kit push --config drizzle.config.ts'",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "knip": "knip",
    "test": "bun test",
    "deploy": "wrangler deploy",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.7.2",
    "@durable-streams/client": "^0.2.1",
    "@electric-sql/client": "^1.5.4",
    "@octokit/webhooks": "^14.2.0",
    "@opencode-ai/sdk": "^1.2.1",
    "@orpc/client": "^1.13.5",
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/electric-db-collection": "^0.2.33",
    "@tanstack/react-db": "0.1.70",
    "@tanstack/react-router": "^1.159.6",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "lucide-react": "^0.563.0",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250121.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@tanstack/router-plugin": "^1.159.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.8",
    "drizzle-kit": "^0.31.8",
    "knip": "^5.82.1",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.61.1"
  }
}

{
  "name": "clanki",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:worker": "wrangler dev",
    "dev:frontend": "vite",
    "dev": "bun run dev:worker & bun run dev:frontend",
    "build:worker": "tsc --noEmit -p tsconfig.worker.json",
    "build:frontend": "tsc --noEmit -p tsconfig.frontend.json && vite build",
    "build:graph": "tsc --noEmit -p tsconfig.graph.json",
    "build": "bun run build:worker && bun run build:frontend && bun run build:graph",
    "graph": "bun graph/src/cli.ts",
    "graph:data": "bun graph/src/generate-data.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "knip": "knip",
    "test": "bun test",
    "deploy": "wrangler deploy",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.7.2",
    "@octokit/webhooks": "^14.2.0",
    "@opencode-ai/sdk": "^1.1.63",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/query-db-collection": "^1.0.22",
    "@tanstack/react-db": "^0.1.69",
    "@tanstack/react-router": "^1.157.16",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250121.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.8",
    "drizzle-kit": "^0.31.8",
    "knip": "^5.82.1",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.61.1"
  }
}

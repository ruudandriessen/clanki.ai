---

---

<section class="hero">
  <div class="hero-inner">
    <div class="badge">Coming soon</div>
    <h1>
      Build your ideas<br />
      <span class="highlight">from anywhere.</span>
    </h1>
    <p class="subtitle">
      Describe what you want. Clanki's AI agents execute it — writing code,
      creating PRs, and shipping features across your codebase.
    </p>
    <a href="#waitlist" class="hero-cta">Get early access</a>
  </div>
</section>

<style>
  .hero {
    padding: 10rem 2rem 6rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-accent);
    border: 1px solid var(--color-border);
    padding: 0.35rem 1rem;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .highlight {
    color: var(--color-primary);
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--color-muted);
    max-width: 540px;
    margin: 0 auto 2.5rem;
  }

  .hero-cta {
    display: inline-block;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    background: var(--color-primary);
    color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.85rem 2.5rem;
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--color-border);
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }

  .hero-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-border);
  }
</style>

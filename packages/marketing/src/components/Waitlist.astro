---

---

<section class="waitlist" id="waitlist">
  <div class="waitlist-inner">
    <h2>Get early access</h2>
    <p class="waitlist-desc">
      Clanki is in private beta. Drop your email and we'll let you in as soon as
      we're ready.
    </p>
    <form class="waitlist-form" data-waitlist-form>
      <input
        type="email"
        name="email"
        placeholder="you@company.com"
        required
        autocomplete="email"
      />
      <button type="submit">Join waitlist</button>
    </form>
    <p class="waitlist-note">No spam. We'll only email you when it's time.</p>
    <p class="error-msg" data-error hidden>
      Something went wrong. Please try again.
    </p>
    <p class="success-msg" data-success hidden>
      You're on the list. We'll be in touch.
    </p>
  </div>
</section>

<style>
  .waitlist {
    padding: 6rem 2rem;
    background: var(--color-text);
    color: var(--color-bg);
  }

  .waitlist-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .waitlist-desc {
    font-size: 1.05rem;
    opacity: 0.8;
    margin-bottom: 2rem;
  }

  .waitlist-form {
    display: flex;
    gap: 0;
    max-width: 460px;
    margin: 0 auto 1rem;
  }

  input[type="email"] {
    flex: 1;
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-bg);
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
  }

  input[type="email"]::placeholder {
    color: var(--color-muted);
  }

  button {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.75rem;
    background: var(--color-primary);
    color: var(--color-surface);
    border: 1px solid var(--color-bg);
    border-left: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }

  button:hover {
    background: var(--color-primary-dark);
  }

  .waitlist-note {
    font-size: 0.8rem;
    opacity: 0.5;
  }

  .success-msg {
    margin-top: 1rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .error-msg {
    margin-top: 1rem;
    font-weight: 600;
    color: #ff6b6b;
  }

  .error-msg[hidden],
  .success-msg[hidden] {
    display: none;
  }
</style>

<script>
  const form = document.querySelector("[data-waitlist-form]") as HTMLFormElement;
  const success = document.querySelector("[data-success]") as HTMLElement;
  const errorMsg = document.querySelector("[data-error]") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const email = data.get("email") as string;
    const button = form.querySelector("button") as HTMLButtonElement;

    button.disabled = true;
    button.textContent = "Submitting…";
    errorMsg.hidden = true;

    try {
      const res = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      if (!res.ok) throw new Error("Request failed");

      form.hidden = true;
      success.hidden = false;
      document.querySelector(".waitlist-note")?.remove();
    } catch {
      button.disabled = false;
      button.textContent = "Join waitlist";
      errorMsg.hidden = false;
    }
  });
</script>

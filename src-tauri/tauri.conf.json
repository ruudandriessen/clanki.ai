{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clanki",
  "version": "0.1.0",
  "identifier": "ai.clanki.desktop",
  "build": {
    "beforeDevCommand": "bun run dev -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run tauri:prepare",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/bun"],
    "resources": {
      "../.output/nitro.json": ".output/nitro.json",
      "../.output/public/**/*": ".output/public/",
      "../.output/server/**/*": ".output/server/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
